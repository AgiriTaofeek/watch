{
  "name": "watch",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome check . && turbo run lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky",
    "db:pg": "docker compose -f deploy/docker-compose.yml up -d",
    "db:up": "docker compose -f deploy/docker-compose.yml --profile db-ui up -d",
    "db:admin": "docker compose -f deploy/docker-compose.yml --profile db-admin up -d",
    "db:down": "docker compose -f deploy/docker-compose.yml --profile db-ui --profile db-admin down",
    "server:dev": "pnpm --filter @watch/server dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
